# Copier ce fichier en .env pour personnaliser la stack Docker locale.
# Pour l'hébergement en ligne (hors Docker), voir .env.production.example.

# Mot de passe root MySQL (dev local uniquement)
DB_PASSWORD=tontine_dev

# Port exposé sur la machine hôte pour l'app PHP/Apache (libre au moment de la config)
APP_PORT=3000

# Port exposé sur la machine hôte pour MySQL (3306 déjà pris par un autre projet)
DB_HOST_PORT=3307

# Port exposé sur la machine hôte pour Adminer (8080-8084 déjà pris par d'autres projets)
ADMINER_PORT=8085
